{
  "name": "stata-all-in-one",
  "displayName": "Stata All in One",
  "description": "Supercharge your Stata workflow in VS Code. An enhanced version of `Stata Outline` with advanced Syntax Highlighting + Code Hints + Smart Outline + Code Execution + Data Viewing + AI Skill. All your Stata needs in one place.",
  "version": "0.3.0",
  "publisher": "ZihaoVistonWang",
  "icon": "img/icon.png",
  "keywords": [
    "stata",
    "do",
    "ado",
    "outline",
    "embedded console",
    "data viewer",
    "code runner",
    "syntax highlighting",
    "stata code",
    "stata do file",
    "stata outline",
    "stata runner",
    "AI coding skill"
  ],
  "engines": {
    "vscode": "^1.70.0"
  },
  "activationEvents": [
    "onLanguage:stata",
    "onCommand:stata-all-in-one.showDataViewer",
    "onCustomEditor:stata-all-in-one.dtaViewer",
    "onStartupFinished"
  ],
  "main": "./main.js",
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "configuration": {
      "title": "Stata All in One",
      "properties": {
        "stata-all-in-one.numberingShow": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.numberingShow.description%"
        },
        "stata-all-in-one.numberingAdd": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.numberingAdd.description%"
        },
        "stata-all-in-one.stataVersionOnMacOS": {
          "type": "string",
          "enum": [
            "",
            "StataMP",
            "StataSE",
            "StataIC",
            "StataBE"
          ],
          "default": "",
          "markdownDescription": "%config.stataVersionOnMacOS.description%"
        },
        "stata-all-in-one.stataPathOnWindows": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.stataPathOnWindows.description%"
        },
        "stata-all-in-one.closeStataOtherWindowsBeforeSendingCode": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.closeStataOtherWindowsBeforeSendingCode.description%"
        },
        "stata-all-in-one.commentStyle": {
          "type": "string",
          "enum": [
            "// ",
            "* ",
            "/* ... */"
          ],
          "default": "// ",
          "markdownDescription": "%config.commentStyle.description%"
        },
        "stata-all-in-one.separatorLength": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "markdownDescription": "%config.separatorLength.description%"
        },
        "stata-all-in-one.customCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "reghdfe"
          ],
          "markdownDescription": "%config.customCommands.description%"
        },
        "stata-all-in-one.separatorSymmetric": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.separatorSymmetric.description%"
        },
        "stata-all-in-one.enableCtrlShiftD": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.enableCtrlShiftD.description%"
        },
        "stata-all-in-one.cdToDoFileDir": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.cdToDoFileDir.description%"
        },
        "stata-all-in-one.runMode": {
          "type": "string",
          "enum": [
            "externalApp",
            "embeddedConsole"
          ],
          "enumItemLabels": [
            "External App",
            "Embedded Console"
          ],
          "default": "embeddedConsole",
          "markdownDescription": "%config.runMode.description%"
        },
        "stata-all-in-one.consoleFontMode": {
          "type": "string",
          "enum": [
            "online",
            "editor",
            "system",
            "custom"
          ],
          "enumItemLabels": [
            "Online CJK Font",
            "Editor Font Family",
            "System Monospace",
            "Custom Font Family"
          ],
          "default": "online",
          "markdownDescription": "%config.consoleFontMode.description%"
        },
        "stata-all-in-one.consoleCustomFontFamily": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.consoleCustomFontFamily.description%"
        },
        "stata-all-in-one.graphPngDpi": {
          "type": "number",
          "default": 600,
          "minimum": 72,
          "maximum": 1200,
          "markdownDescription": "%config.graphPngDpi.description%"
        },
        "stata-all-in-one.showActionButtons": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.showActionButtons.description%"
        },
        "stata-all-in-one.enableHoverDocs": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.enableHoverDocs.description%"
        },
        "stata-all-in-one.additionalAdoPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "%config.additionalAdoPaths.description%"
        }
      }
    },
    "configurationDefaults": {
      "[stata]": {
        "editor.quickSuggestions": {
          "other": true,
          "comments": false,
          "strings": false
        },
        "editor.suggestOnTriggerCharacters": true,
        "editor.wordBasedSuggestions": "off"
      }
    },
    "languages": [
      {
        "id": "stata",
        "aliases": [
          "Stata",
          "stata"
        ],
        "extensions": [
          ".do",
          ".ado",
          ".mata"
        ],
        "configuration": "./grammars/language_config.json"
      }
    ],
    "grammars": [
      {
        "language": "stata",
        "scopeName": "source.stata",
        "path": "./grammars/stata.json"
      },
      {
        "scopeName": "stata.injection.custom-commands",
        "path": "./grammars/stata-custom.json",
        "injectTo": [
          "source.stata"
        ]
      }
    ],
    "customEditors": [
      {
        "viewType": "stata-all-in-one.dtaViewer",
        "displayName": "%customEditor.dtaViewer.displayName%",
        "selector": [
          {
            "filenamePattern": "*.dta"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "stata-all-in-one.setLevel1",
        "title": "%command.setLevel1.title%"
      },
      {
        "command": "stata-all-in-one.setLevel2",
        "title": "%command.setLevel2.title%"
      },
      {
        "command": "stata-all-in-one.setLevel3",
        "title": "%command.setLevel3.title%"
      },
      {
        "command": "stata-all-in-one.setLevel4",
        "title": "%command.setLevel4.title%"
      },
      {
        "command": "stata-all-in-one.setLevel5",
        "title": "%command.setLevel5.title%"
      },
      {
        "command": "stata-all-in-one.setLevel6",
        "title": "%command.setLevel6.title%"
      },
      {
        "command": "stata-all-in-one.clearHeading",
        "title": "%command.clearHeading.title%"
      },
      {
        "command": "stata-all-in-one.runSection",
        "title": "%command.runSection.title%",
        "icon": "$(play)"
      },
      {
        "command": "stata-all-in-one.openSettings",
        "title": "%command.openSettings.title%",
        "icon": "$(settings-gear)"
      },
      {
        "command": "stata-all-in-one.reportBug",
        "title": "%command.reportBug.title%"
      },
      {
        "command": "stata-all-in-one.showSponsor",
        "title": "%command.showSponsor.title%"
      },
      {
        "command": "stata-all-in-one.showDataViewer",
        "title": "%command.showDataViewer.title%",
        "icon": "$(table)"
      },
      {
        "command": "stata-all-in-one.insertCustomSeparator",
        "title": "%command.insertCustomSeparator.title%"
      },
      {
        "command": "stata-all-in-one.insertSeparatorDash",
        "title": "%command.insertSeparatorDash.title%"
      },
      {
        "command": "stata-all-in-one.insertSeparatorEqual",
        "title": "%command.insertSeparatorEqual.title%"
      },
      {
        "command": "stata-all-in-one.insertSeparatorStar",
        "title": "%command.insertSeparatorStar.title%"
      },
      {
        "command": "stata-all-in-one.updateAllSeparators",
        "title": "%command.updateAllSeparators.title%"
      },
      {
        "command": "stata-all-in-one.showHelp",
        "title": "%command.showHelp.title%"
      },
      {
        "command": "stata-all-in-one.insertLineBreak",
        "title": "%command.insertLineBreak.title%"
      },
      {
        "command": "stata-all-in-one.resetStataVersionOnMacOS",
        "title": "%command.resetStataVersionOnMacOS.title%"
      },
      {
        "command": "stata-all-in-one.debugResetMigrationPrompt",
        "title": "%command.debugResetMigrationPrompt.title%"
      },
      {
        "command": "stata-all-in-one.debugTestUpdateNotification",
        "title": "%command.debugTestUpdateNotification.title%"
      },
      {
        "command": "stata-all-in-one.debugResetEmbeddedConsoleOverflowNotice",
        "title": "%command.debugResetEmbeddedConsoleOverflowNotice.title%"
      },
      {
        "command": "stata-all-in-one.rename",
        "title": "%command.rename.title%"
      },
      {
        "command": "stata-all-in-one.stopConsoleExecution",
        "title": "%command.stopConsoleExecution.title%",
        "icon": "$(stop-circle)"
      },
      {
        "command": "stata-all-in-one.diagnoseConsole",
        "title": "%command.diagnoseConsole.title%"
      },
      {
        "command": "stata-all-in-one.showAISkillDialog",
        "title": "%command.showAISkillDialog.title%"
      }
    ],
    "keybindings": [
      {
        "command": "stata-all-in-one.runSection",
        "key": "ctrl+d",
        "mac": "cmd+d",
        "when": "editorTextFocus && editorLangId == stata && !config.stata-all-in-one.enableCtrlShiftD"
      },
      {
        "command": "stata-all-in-one.runSection",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "editorTextFocus && editorLangId == stata && config.stata-all-in-one.enableCtrlShiftD"
      },
      {
        "command": "stata-all-in-one.insertSeparatorDash",
        "key": "ctrl+-",
        "mac": "cmd+-",
        "when": "editorTextFocus && editorLangId == stata"
      },
      {
        "command": "stata-all-in-one.insertSeparatorEqual",
        "key": "ctrl+=",
        "mac": "cmd+=",
        "when": "editorTextFocus && editorLangId == stata"
      },
      {
        "command": "stata-all-in-one.insertSeparatorStar",
        "key": "ctrl+shift+8",
        "mac": "cmd+shift+8",
        "when": "editorTextFocus && editorLangId == stata"
      },
      {
        "command": "stata-all-in-one.insertCustomSeparator",
        "key": "ctrl+alt+s",
        "mac": "ctrl+cmd+s",
        "when": "editorTextFocus && editorLangId == stata"
      },
      {
        "command": "stata-all-in-one.toggleComment",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "editorTextFocus && editorLangId == stata"
      },
      {
        "command": "stata-all-in-one.setLevel1",
        "key": "ctrl+1",
        "mac": "cmd+1",
        "when": "editorTextFocus && editorLangId == stata"
      },
      {
        "command": "stata-all-in-one.setLevel2",
        "key": "ctrl+2",
        "mac": "cmd+2",
        "when": "editorTextFocus && editorLangId == stata"
      },
      {
        "command": "stata-all-in-one.setLevel3",
        "key": "ctrl+3",
        "mac": "cmd+3",
        "when": "editorTextFocus && editorLangId == stata"
      },
      {
        "command": "stata-all-in-one.setLevel4",
        "key": "ctrl+4",
        "mac": "cmd+4",
        "when": "editorTextFocus && editorLangId == stata"
      },
      {
        "command": "stata-all-in-one.setLevel5",
        "key": "ctrl+5",
        "mac": "cmd+5",
        "when": "editorTextFocus && editorLangId == stata"
      },
      {
        "command": "stata-all-in-one.setLevel6",
        "key": "ctrl+6",
        "mac": "cmd+6",
        "when": "editorTextFocus && editorLangId == stata"
      },
      {
        "command": "stata-all-in-one.clearHeading",
        "key": "ctrl+0",
        "mac": "cmd+0",
        "when": "editorTextFocus && editorLangId == stata"
      },
      {
        "command": "stata-all-in-one.showHelp",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h",
        "when": "editorTextFocus && editorLangId == stata"
      },
      {
        "command": "stata-all-in-one.insertLineBreak",
        "key": "shift+enter",
        "mac": "shift+enter",
        "when": "editorTextFocus && editorLangId == stata"
      },
      {
        "command": "stata-all-in-one.rename",
        "key": "f2",
        "when": "editorTextFocus && editorLangId == stata"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "stata-all-in-one.showSponsor",
          "title": "%command.showSponsor.short%",
          "when": "editorLangId == stata && config.stata-all-in-one.showActionButtons",
          "group": "navigation@1"
        },
        {
          "command": "stata-all-in-one.showAISkillDialog",
          "when": "editorLangId == stata && config.stata-all-in-one.showActionButtons",
          "group": "navigation@1.8"
        },
        {
          "command": "stata-all-in-one.reportBug",
          "title": "%command.reportBug.short%",
          "when": "editorLangId == stata && config.stata-all-in-one.showActionButtons",
          "group": "navigation@0"
        },
        {
          "command": "stata-all-in-one.runSection",
          "when": "editorLangId == stata",
          "group": "navigation@2"
        },
        {
          "command": "stata-all-in-one.openSettings",
          "when": "editorLangId == stata",
          "group": "navigation@3"
        }
      ],
      "view/title": [
        {
          "command": "stata-all-in-one.runSection",
          "when": "view == outline && resourceLangId == stata",
          "group": "navigation"
        }
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ZihaoVistonWang/stata-all-in-one"
  },
  "changelog": {
    "url": "https://github.com/ZihaoVistonWang/stata-all-in-one/blob/main/CHANGELOG.md"
  },
  "dependencies": {
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "devDependencies": {
    "node-addon-api": "^8.0.0",
    "node-gyp": "^10.0.0"
  },
  "scripts": {
    "test": "node --test src/__tests__/**/*.test.js",
    "build:native": "bash scripts/build-native.sh",
    "build:native:win": "powershell -ExecutionPolicy Bypass -File scripts/build-native.ps1",
    "prepackage": "npm run build:native"
  }
}
